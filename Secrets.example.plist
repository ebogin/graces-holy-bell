<?xml version="1.0" encoding="UTF-8"?>
<!--
  Template for PostHog secrets.

  Setup: copy this file to "Graces Holy Bell/Secrets.plist" (gitignored) and fill
  in your PostHog project values. Without it — or with an empty key — the app
  falls back to the no-op analytics transport, so it still builds and runs.

  The file lives inside the "Graces Holy Bell/" synchronized group, so Xcode
  bundles it as a resource automatically (no project.pbxproj edits needed).

  Host: use the INGESTION endpoint, not the dashboard URL.
    EU Cloud -> https://eu.i.posthog.com
    US Cloud -> https://us.i.posthog.com
-->
<plist version="1.0">
<dict>
	<key>POSTHOG_API_KEY</key>
	<string></string>
	<key>POSTHOG_HOST</key>
	<string>https://eu.i.posthog.com</string>
</dict>
</plist>
